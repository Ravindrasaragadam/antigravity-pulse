# Environment variables for Market Pulse Dashboard
# Copy this file to .env.local and fill in your credentials

# =============================================================================
# SUPABASE (Required)
# =============================================================================
# Get these from your Supabase Project Settings → API
# https://app.supabase.com/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# NVIDIA NIM (Optional - for AI Analysis API)
# =============================================================================
# Get API key from: https://build.nvidia.com
# This is used server-side only for the /api/ai-analyze endpoint

NVIDIA_NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_NIM_API_URL=https://integrate.api.nvidia.com/v1/chat/completions

# =============================================================================
# OPTIONAL: Analytics & Monitoring
# =============================================================================
# Uncomment and set if you want to add monitoring

# NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================
# Set to 'true' to use mock data instead of real APIs (useful for UI development)

# USE_MOCK_DATA=false
